Options -MultiViews
RewriteEngine On

# English aliases → Spanish canonical pages
Redirect 301 /privacy  /privacidad
Redirect 301 /terms    /terminos

# Serve .html files for clean URLs (e.g. /apps → /apps.html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
